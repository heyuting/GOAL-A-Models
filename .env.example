# Copy to .env.local and fill in values (*.local is gitignored).
# Vite only exposes variables prefixed with VITE_.
# Restart the dev server after changes.

# Highest permission — Manager (unlimited locations)
VITE_MANAGER_EMAILS=you@yale.edu

# Unlimited locations — Developer
# VITE_DEVELOPER_EMAILS=dev@yale.edu

# 20 locations per run — Elevated
# VITE_ELEVATED_EMAILS=collaborator@yale.edu,partner@example.com

# Backend API (optional; defaults to Vite proxy target)
# VITE_API_BASE_URL=http://localhost:8000
