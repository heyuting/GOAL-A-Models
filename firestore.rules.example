rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles: clients may create/read their own doc and update non-tier fields.
    // Tier elevation must be done in Firebase Console / Admin SDK (or Cloud Function).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.tier == 'standard';

      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.tier == resource.data.tier;

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Saved models (existing app behavior — tighten as needed)
    match /savedModels/{modelId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }
  }
}
